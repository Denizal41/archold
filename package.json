{
  "name": "arc-hold",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "npm run test:unit && npm run contract:test",
    "test:unit": "vitest run",
    "contract:build": "hardhat build",
    "contract:sync": "npm run contract:build && node scripts/export-bytecode.mjs",
    "contract:test": "hardhat test nodejs",
    "contract:preflight": "hardhat run scripts/deploy-preflight.ts --build-profile production --network arcTestnet",
    "contract:deploy": "hardhat run scripts/deploy.ts --build-profile production --network arcTestnet"
  },
  "dependencies": {
    "@fontsource/dm-mono": "5.2.7",
    "@fontsource/manrope": "5.2.8",
    "@fontsource/playfair-display": "5.2.8",
    "@vitejs/plugin-react": "6.0.3",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "viem": "2.55.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@nomicfoundation/hardhat-network-helpers": "3.0.11",
    "@nomicfoundation/hardhat-node-test-runner": "3.0.17",
    "@nomicfoundation/hardhat-viem": "3.0.9",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "hardhat": "3.9.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  },
  "overrides": {
    "@actions/http-client": "4.0.1"
  }
}
